generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ReleaseQueue {
  id             String   @id @default(cuid())
  albumTitle     String
  artist         String
  releaseDate    DateTime
  megaS4FileName String
  status         String   // e.g., 'HELD' or 'RELEASED'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
