generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ReleaseQueue {
  id             String   @id @default(cuid())
  albumTitle     String
  artist         String
  releaseDate    DateTime
  megaS4FileName String
  status         String   // e.g., 'HELD' or 'RELEASED'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
